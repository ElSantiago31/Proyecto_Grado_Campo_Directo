# ==============================================================================
# PROYECTO GRADO CAMPO DIRECTO - VARIABLES DE ENTORNO (EJEMPLO)
# ==============================================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores REALES en .env
# 3. NUNCA subas tu archivo .env a GitHub
# ==============================================================================

# -----------------
# SEGURIDAD
# -----------------
SECRET_KEY=<REEMPLAZA-CON-UNA-CLAVE-SECRETA-ALEATORIA>
DEBUG=False
ALLOWED_HOSTS=<tu-dominio.pythonanywhere.com>
SECURE_SSL_REDIRECT=False

# -----------------
# BASE DE DATOS
# -----------------
PROD_DB_HOST=<host-de-bd-de-pythonanywhere>
PROD_DB_NAME=<nombre-de-tu-base-de-datos>
PROD_DB_USER=<tu-usuario-de-pythonanywhere>
PROD_DB_PASSWORD=<contrasena-de-tu-base-de-datos>
PROD_DB_PORT=3306

# -----------------
# CORREO (Notificaciones de Pedidos)
# -----------------
# Guia para crear contrasena de aplicacion de Gmail:
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=<servidor-smtp-ej-smtp.gmail.com>
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=<tu-correo@ejemplo.com>
EMAIL_HOST_PASSWORD=<contrasena-de-aplicacion-de-16-digitos>
DEFAULT_FROM_EMAIL=Campo Directo <<tu-correo@ejemplo.com>>
